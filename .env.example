# ============================================================
# WA Sender Pro — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ============================================================

# --- App Configuration & Public Domain ---
# NODE_ENV: imposta 'development' per test locali o 'production' per server esposti su internet.
NODE_ENV=development

# NUXT_PUBLIC_APP_URL: URL PUBBLICO della tua applicazione WaForge.
# ATTENZIONE (Framework Nuxt/Next.js): Le variabili che iniziano con NUXT_PUBLIC_ vengono incorporate nel codice
# Javascript inviato al browser dell'utente! Se pubblichi l'app su internet con un dominio (es. https://waforge.iltuodominio.com),
# DEVI cambiare questa variabile con il tuo URL pubblico, altrimenti le chiamate API dal browser falliranno per errori CORS!
# locale: http://localhost:3000 | produzione: https://waforge.iltuodominio.com
NUXT_PUBLIC_APP_URL=http://localhost:3000

# APP_SECRET viene utilizzato per firmare i token JWT. Deve avere almeno 32 caratteri.
# Puoi generare una stringa sicura usando il comando da terminale: openssl rand -base64 32
APP_SECRET=change-me-to-a-random-32-char-string

# --- WhatsApp Engine ---
# Choose backend: "wuzapi" (asternic/wuzapi), "gowa" (aldinokemal/go-whatsapp-web-multidevice), "openwa" (rmyndharis/OpenWA) or "hybrid" (Multi-Engine Load Balancing & Failover)
WHATSAPP_ENGINE=hybrid

# --- WuzAPI (primary) ---
# https://github.com/asternic/wuzapi
# API Token e Chiavi di Crittografia globale per WuzAPI.
# Per generare WUZAPI_TOKEN (16 hex): openssl rand -hex 16
# Per generare WUZAPI_GLOBAL_ENCRYPTION_KEY e HMAC_KEY (32 alfanumerici o base64): openssl rand -base64 32
WUZAPI_URL=http://wuzapi:3100
WUZAPI_TOKEN=your-secret-wuzapi-token
WUZAPI_GLOBAL_ENCRYPTION_KEY=3ao9Me9qJSEgaShrL0LegV4Ml3LxeC2A
WUZAPI_GLOBAL_HMAC_KEY=tfODXBzg9ZOgJrlwDyZuFBINeU0xjSjv

# --- go-whatsapp-web-multidevice (fallback 1) ---
# https://github.com/aldinokemal/go-whatsapp-web-multidevice
# API Token di sicurezza. Per generare GOWA_TOKEN: openssl rand -hex 16
# Per generare GOWA_APP_SECRET (segreto per la firma dei webhook): openssl rand -hex 24
GOWA_URL=http://gowa:3000
GOWA_TOKEN=your-secret-gowa-token
GOWA_APP_SECRET=your-secret-gowa-webhook-key

# --- OpenWA (fallback 2 / Node.js Baileys engine) ---
# https://github.com/rmyndharis/OpenWA
# Chiave API di sicurezza per OpenWA. Per generare OPENWA_API_KEY: openssl rand -hex 16
OPENWA_URL=http://openwa:2785/api
OPENWA_API_KEY=owa_k1_secret


# --- Database (PostgreSQL) ---
# Imposta queste variabili e docker-compose le userà per costruire l'URI automaticamente
# È caldamente consigliato generare una password sicura per il database, ad esempio con: openssl rand -hex 16
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=waforge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# URL calcolato usato da Prisma in locale
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# Redis connection for Job Queues (BullMQ)
REDIS_URL="redis://localhost:6379"

# --- Campaign Defaults ---
# Delay between messages in seconds (min/max for randomization / anti-ban jitter)
CAMPAIGN_DELAY_MIN=15
CAMPAIGN_DELAY_MAX=45

# --- Rate Limiting ---
# Max messages per hour (safety cap)
MAX_MESSAGES_PER_HOUR=100

# --- Anti-Ban ---
SPINTAX_ENABLED=true

# --- Debug & Granular Container Log Levels ---
# Options: 'info', 'debug', 'warn', 'error', 'verbose'
ENABLE_DEBUG_WIDGET=true
NUXT_PUBLIC_ENABLE_DEBUG_WIDGET=true
LOG_LEVEL_WAFORGE=verbose
LOG_LEVEL_WUZAPI=info
LOG_LEVEL_GOWA=info
LOG_LEVEL_OPENWA=info
LOG_LEVEL_COCKPIT=info
LOG_LEVEL_MCP=info


# ─── TRAEFIK DEPLOYMENT ───────────────────────────────────────────────────
TRAEFIK_ENABLE=true
DOMAIN=waforge.iltuodominio.com
WEBSECURE_ENTRYPOINT=websecure
CERT_RESOLVER=myresolver

# --- Email / SMTP (Invites & Notifications) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME="WaForge"

# --- OAuth2 / SSO (e.g. PocketID) ---
# Se configurati, abilitano l'accesso tramite il pulsante SSO nella pagina di Login
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_AUTHORIZE_URL=https://pocketid.example.com/oauth/authorize
OAUTH_TOKEN_URL=https://pocketid.example.com/oauth/token
OAUTH_USERINFO_URL=https://pocketid.example.com/oauth/userinfo

# ============================================================
# --- Crikket Bug Reporting & Automated Issue Tracker ---
# https://github.com/redpangilinan/crikket
# Container dedicati per il tracciamento, logging e analisi errori AI
# ============================================================
# Per generare una password sicura per il DB Crikket: openssl rand -hex 16
CRIKKET_POSTGRES_USER=crikket
CRIKKET_POSTGRES_PASSWORD=crikket_secret_change_me
CRIKKET_POSTGRES_DB=crikket
CRIKKET_POSTGRES_PORT=5434

# Porte host per il server API e la Web Dashboard Crikket (isolate da WuzAPI 3100 e Gowa 3200)
CRIKKET_SERVER_PORT=3150
CRIKKET_WEB_PORT=3151

# URL Pubblici, Domini e Configurazione CORS per Crikket (Framework Next.js / BetterAuth)
# ATTENZIONE (Pubblicazione con Dominio Custom e Reverse Proxy Traefik in UN UNICO DOMINIO):
# Crikket è configurato per esporre sia la Web Dashboard che le API Server sotto UN UNICO DOMINIO in Traefik!
# Il router Traefik instrada automaticamente le rotte di API e autenticazione (/api, /better-auth, /trpc, /storage)
# al server API (porta 3000) con priorità 20, e tutte le altre pagine al frontend Next.js (porta 3001) con priorità 10.
# In questo modo non hai bisogno di configurare due sottodomini distinti!
# Imposta:
# - CRIKKET_DOMAIN: Il tuo dominio unico per Crikket (es. crikket.iltuodominio.com)
# - CRIKKET_PUBLIC_URL: L'URL pubblico completo con https (es. https://crikket.iltuodominio.com)
# - CRIKKET_CORS_ORIGINS: Elenco di origini permesse (es. https://crikket.iltuodominio.com,https://waforge.iltuodominio.com)
CRIKKET_DOMAIN=crikket.iltuodominio.com
# CRIKKET_PUBLIC_URL=http://localhost:3151
CRIKKET_CORS_ORIGINS=http://localhost:3000,http://localhost:3151,http://192.168.87.223:3151,http://192.168.87.223:3150,http://192.168.87.223:3000

# Configurazione facoltativa per chi volesse comunque dividere in due sottodomini distinti:
CRIKKET_PUBLIC_SERVER_URL=http://localhost:3150
CRIKKET_PUBLIC_WEB_URL=http://localhost:3151
CRIKKET_WEB_DOMAIN=crikket.iltuodominio.com
CRIKKET_API_DOMAIN=crikket-api.iltuodominio.com

# BETTER_AUTH_SECRET deve avere almeno 32 caratteri per la crittografia sicura dei cookie/token di Crikket.
# Per generare BETTER_AUTH_SECRET dal terminale: openssl rand -base64 32
BETTER_AUTH_SECRET=crikket_super_secret_auth_key_32chars

# Configurazione Object Storage (Mock locale predefinito per evitare errori all'avvio)
CRIKKET_STORAGE_BUCKET=mock-bucket
CRIKKET_STORAGE_ACCESS_KEY_ID=mock-key
CRIKKET_STORAGE_SECRET_ACCESS_KEY=mock-secret
CRIKKET_STORAGE_ENDPOINT=http://localhost:9000



