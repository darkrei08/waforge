# ============================================================
# WaForge — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ============================================================

# --- App ---
NODE_ENV=development
NUXT_PUBLIC_APP_URL=http://localhost:3000
# APP_SECRET viene utilizzato per firmare i token JWT. Deve avere almeno 32 caratteri.
# Puoi generare una stringa sicura usando il comando da terminale: openssl rand -base64 32
APP_SECRET=change-me-to-a-random-32-char-string

# --- WhatsApp Engine ---
# Choose backend: "wuzapi" (asternic/wuzapi), "gowa" (aldinokemal/go-whatsapp-web-multidevice), "openwa" (rmyndharis/OpenWA) or "hybrid" (Multi-Engine Load Balancing & Failover)
WHATSAPP_ENGINE=hybrid

# --- WuzAPI (primary) ---
# https://github.com/asternic/wuzapi
# API Token di sicurezza. Genera una stringa sicura (es. con il comando: openssl rand -hex 16)
WUZAPI_URL=http://wuzapi:3100
WUZAPI_TOKEN=your-secret-wuzapi-token
WUZAPI_GLOBAL_ENCRYPTION_KEY=your-random-32-char-string
WUZAPI_GLOBAL_HMAC_KEY=your-random-32-char-string

# --- go-whatsapp-web-multidevice (fallback 1) ---
# https://github.com/aldinokemal/go-whatsapp-web-multidevice
# API Token di sicurezza. Genera una stringa sicura (es. con il comando: openssl rand -hex 16)
GOWA_URL=http://gowa:3000
GOWA_TOKEN=your-secret-gowa-token

# --- OpenWA (fallback 2 / Node.js Baileys engine) ---
# https://github.com/rmyndharis/OpenWA
OPENWA_URL=http://openwa:2785/api
OPENWA_API_KEY=owa_k1_your-secret-api-key

# --- Database (PostgreSQL) ---
# Imposta queste variabili e docker-compose le userà per costruire l'URI automaticamente
# È caldamente consigliato generare una password sicura per il database, ad esempio con: openssl rand -hex 16
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=waforge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# URL calcolato usato da Prisma in locale
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# Redis connection for Job Queues (BullMQ)
REDIS_URL="redis://localhost:6379"

# --- Campaign Defaults ---
# Delay between messages in seconds (min/max for randomization / anti-ban jitter)
CAMPAIGN_DELAY_MIN=15
CAMPAIGN_DELAY_MAX=45

# --- Rate Limiting ---
# Max messages per hour (safety cap)
MAX_MESSAGES_PER_HOUR=100

# --- Anti-Ban ---
SPINTAX_ENABLED=true

# --- Debug ---
ENABLE_DEBUG_WIDGET=true
NUXT_PUBLIC_ENABLE_DEBUG_WIDGET=true

# ─── TRAEFIK DEPLOYMENT ───────────────────────────────────────────────────
TRAEFIK_ENABLE=true
DOMAIN=waforge.iltuodominio.com
WEBSECURE_ENTRYPOINT=websecure
CERT_RESOLVER=myresolver

# --- Email / SMTP (Invites & Notifications) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME="WaForge"

# --- OAuth2 / SSO (e.g. PocketID) ---
# Se configurati, abilitano l'accesso tramite il pulsante SSO nella pagina di Login
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_AUTHORIZE_URL=https://pocketid.example.com/oauth/authorize
OAUTH_TOKEN_URL=https://pocketid.example.com/oauth/token
OAUTH_USERINFO_URL=https://pocketid.example.com/oauth/userinfo
