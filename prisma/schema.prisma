// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Authentication & Multi-Tenancy ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  
  isSuperAdmin  Boolean   @default(false)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships   TeamMembership[]
  messagesSent  ChatMessage[] // for auditing who replied in live chat
}

model Team {
  id            String    @id @default(cuid())
  name          String
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  members       TeamMembership[]
  
  contacts      Contact[]
  templates     Template[]
  campaigns     Campaign[]
  waSessions    WhatsAppSession[]
  chatMessages  ChatMessage[]
}

model TeamMembership {
  id        String   @id @default(cuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  role      String   @default("AGENT") // OWNER, ADMIN, AGENT
  
  createdAt DateTime @default(now())
  
  @@unique([userId, teamId])
}

// ── Contacts & CRM ───────────────────────────────────────────────────────────

model Contact {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  name        String
  prefix      String   @default("+39")
  phone       String
  fullPhone   String   // computed: prefix+phone (digits only)
  email       String?
  company     String?
  notes       String?  // Rich text or simple notes for the CRM
  customFields String? // JSON blob for extra CSV columns
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  messages    Message[]
  chatHistory ChatMessage[]
  
  @@unique([teamId, fullPhone])
  @@index([fullPhone])
}

// ── Templates ────────────────────────────────────────────────────────────────

model Template {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  name        String
  body        String   // supports {{Name}}, {{email}}, etc.
  description String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns   Campaign[]
}

// ── Campaigns ────────────────────────────────────────────────────────────────

model Campaign {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  name        String
  status      String   @default("DRAFT")
  
  templateId  String
  template    Template @relation(fields: [templateId], references: [id])
  
  // Contact filter (JSON array of contact IDs, or "ALL")
  contactIds  String   @default("ALL")
  
  // Rate limiting
  delayMin    Int      @default(15) // seconds
  delayMax    Int      @default(45) // seconds
  
  // Stats
  totalCount  Int      @default(0)
  sentCount   Int      @default(0)
  failedCount Int      @default(0)
  
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    Message[]
}

// ── Messages (individual send log for campaigns) ─────────────────────────────

model Message {
  id          String    @id @default(cuid())
  
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  
  body        String    // final rendered message
  status      String    @default("PENDING")
  errorReason String?
  
  wuzapiMsgId String?   // WuzAPI message ID for tracking
  
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
}

// ── Live Chat History (Inbound/Outbound) ─────────────────────────────────────

model ChatMessage {
  id          String    @id @default(cuid())
  
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  direction   String    // "INBOUND" or "OUTBOUND"
  content     String
  
  wuzapiMsgId String?   @unique
  status      String    @default("DELIVERED") // SENT, DELIVERED, READ
  
  senderId    String?   // If sent by an agent via dashboard
  sender      User?     @relation(fields: [senderId], references: [id])
  
  createdAt   DateTime  @default(now())
}

// ── WhatsApp Session (Multi-Tenant) ──────────────────────────────────────────

model WhatsAppSession {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  token     String   @unique // WuzAPI user token specific to this team
  status    String   @default("disconnected") // connected|disconnected|connecting
  phone     String?  // connected phone number
  updatedAt DateTime @updatedAt
}
