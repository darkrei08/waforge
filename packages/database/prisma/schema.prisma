// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Authentication & Multi-Tenancy ───────────────────────────────────────────

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  name         String

  isSuperAdmin Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships  TeamMembership[]
  messagesSent ChatMessage[] // for auditing who replied in live chat
}

model Team {
  id            String    @id @default(cuid())
  name          String
  description   String?
  tags          String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members TeamMembership[]

  contacts            Contact[]
  contactGroups       ContactGroup[]
  templates           Template[]
  campaigns           Campaign[]
  waSessions          WhatsAppSession[]
  chatMessages        ChatMessage[]
  waConversations     WhatsAppConversation[]
  waScheduledMessages WhatsAppScheduledMessage[]

  planTier             String?   @default("FREE") // FREE, BASIC, PRO, ENTERPRISE
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String?   // active, past_due, canceled
  currentPeriodEnd     DateTime?

  brandSettings Json?
  llmSettings   Json?
}

model TeamMembership {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  role String @default("AGENT") // OWNER, ADMIN, AGENT

  createdAt DateTime @default(now())

  @@unique([userId, teamId])
}

// ── Contact Groups (Rubriche) ──────────────────────────────────────────────────

model ContactGroup {
  id          String    @id @default(cuid())
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  tags        String?
  color       String?
  
  contacts    Contact[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([teamId, name])
}

// ── Contacts & CRM ───────────────────────────────────────────────────────────

model Contact {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  name         String
  prefix       String  @default("+39")
  phone        String
  fullPhone    String // computed: prefix+phone (digits only)
  email        String?
  company      String?
  notes        String? // Rich text or simple notes for the CRM
  customFields String? // JSON blob for extra CSV columns
  isActive     Boolean @default(true)

  // Enhanced CRM fields & multi-number support
  source          String  @default("manual") // manual, webhook, import
  labels          String? @default("[]") // JSON array of label tags e.g. ["VIP", "Struttura"]
  secondaryPhones String? @default("[]") // JSON array e.g. ["+39333111222"]
  pec             String? // PEC email
  declarantName   String? // Nome del dichiarante / referente
  declarantPhone  String? // Telefono del dichiarante / referente

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Consent Policy
  optInMarketing     Boolean @default(true)
  optInTransactional Boolean @default(true)
  gdprNotified       Boolean @default(false)
  consentStatus      String  @default("PENDING") // PENDING, GRANTED, DENIED

  // WhatsApp verification (null = not checked, true/false = verified)
  isOnWhatsApp Boolean?

  // Relations
  groups              ContactGroup[]
  messages            Message[]
  chatHistory         ChatMessage[]
  waConversations     WhatsAppConversation[]
  waScheduledMessages WhatsAppScheduledMessage[]

  @@unique([teamId, fullPhone])
  @@index([fullPhone])
}

// ── Templates ────────────────────────────────────────────────────────────────

model Template {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  name        String
  body        String // supports {{Name}}, {{email}}, etc.
  description String?

  // Media attachment (optional)
  mediaUrl  String? // URL of image/video/document/audio
  mediaType String  @default("text") // text, image, video, document, audio

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns Campaign[]
}

// ── Campaigns ────────────────────────────────────────────────────────────────

model Campaign {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  name   String
  status String @default("DRAFT")

  templateId String
  template   Template @relation(fields: [templateId], references: [id])

  // Contact filter (JSON array of contact IDs, or "ALL")
  contactIds String @default("ALL")

  // Rate limiting
  delayMin Int @default(15) // seconds
  delayMax Int @default(45) // seconds

  // GDPR Compliance
  includeGdprDisclaimer Boolean @default(false)

  // Stats
  totalCount  Int @default(0)
  sentCount   Int @default(0)
  failedCount Int @default(0)
  optOutCount Int @default(0)

  scheduledAt DateTime? // Optional future start date/time
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  messages Message[]
}

// ── Messages (individual send log for campaigns) ─────────────────────────────

model Message {
  id String @id @default(cuid())

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  body        String // final rendered message
  status      String  @default("PENDING")
  errorReason String?

  wuzapiMsgId String? // WuzAPI message ID for tracking

  sentAt    DateTime?
  createdAt DateTime  @default(now())
}

// ── Live Chat History (Inbound/Outbound) ─────────────────────────────────────

model ChatMessage {
  id String @id @default(cuid())

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  direction String // "INBOUND" or "OUTBOUND"
  content   String

  wuzapiMsgId String? @unique
  wamid       String? @unique // GOWA message ID
  status      String  @default("DELIVERED") // SENT, DELIVERED, READ

  type     String @default("text") // text, image, audio, document, reaction
  metadata Json? // stores mediaUrl, reaction emoji, etc

  conversationId String?
  conversation   WhatsAppConversation? @relation(fields: [conversationId], references: [id])

  senderId String? // If sent by an agent via dashboard
  sender   User?   @relation(fields: [senderId], references: [id])

  createdAt DateTime @default(now())
}

// ── WhatsApp Session (Multi-Tenant) ──────────────────────────────────────────

model WhatsAppSession {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  token       String   @unique // WuzAPI user token specific to this team
  status      String   @default("disconnected") // connected|disconnected|connecting
  phone       String? // connected phone number
  name        String? // custom device name
  description String? // custom device description
  tags        String? // JSON or comma separated tags
  updatedAt   DateTime @updatedAt
}

// ── GOWA (Cloud API) Specific Models ─────────────────────────────────────────

model WhatsAppConversation {
  id        String  @id @default(cuid())
  teamId    String
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  unreadCount   Int      @default(0)
  lastMessageAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@unique([teamId, contactId])
}

model WhatsAppScheduledMessage {
  id        String  @id @default(cuid())
  teamId    String
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  content  String
  type     String @default("text") // text, media, etc
  metadata Json? // store media URLs, etc

  scheduledFor DateTime
  status       String   @default("PENDING") // PENDING, SENT, FAILED
  errorReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
