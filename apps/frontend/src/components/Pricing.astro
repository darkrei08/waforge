---
import { SiteConfig } from '../config';
---

<section id="pricing" class="py-24 relative overflow-hidden bg-background">
  <!-- Glowing effects -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-secondary/10 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-6 text-white tracking-tight">Scegli il piano giusto per te</h2>
      <p class="text-text-muted text-lg max-w-2xl mx-auto">Tutti i piani includono l'accesso alla dashboard {SiteConfig.brandName}. Scala la tua operatività senza pensieri.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      
      <!-- Free/Trial -->
      <div class="glass-panel rounded-3xl p-8 flex flex-col border border-white/5 hover:border-white/20 transition-all">
        <h3 class="text-2xl font-bold text-white mb-2">Starter</h3>
        <p class="text-text-muted mb-6">Perfetto per testare la piattaforma.</p>
        <div class="mb-6">
          <span class="text-4xl font-bold text-white">€0</span>
          <span class="text-text-muted">/mese</span>
        </div>
        <ul class="space-y-4 mb-8 flex-1">
          <li class="flex items-center gap-3 text-text-muted">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            1 Dispositivo WhatsApp
          </li>
          <li class="flex items-center gap-3 text-text-muted">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Fino a 100 contatti
          </li>
          <li class="flex items-center gap-3 text-text-muted">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Supporto base
          </li>
        </ul>
        <a href={`${SiteConfig.dashboardUrl}/register`} class="btn-pricing-secondary">
          Inizia Gratis
        </a>
      </div>

      <!-- Pro -->
      <div class="glass-panel rounded-3xl p-8 flex flex-col pricing-card-pro">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-black font-bold px-4 py-1 rounded-full text-sm">Più Popolare</div>
        <h3 class="text-2xl font-bold text-white mb-2">Business</h3>
        <p class="text-text-muted mb-6">Per agenzie che fanno sul serio.</p>
        <div class="mb-6">
          <span class="text-4xl font-bold text-white">€49</span>
          <span class="text-text-muted">/mese</span>
        </div>
        <ul class="space-y-4 mb-8 flex-1">
          <li class="flex items-center gap-3 text-text-muted">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Fino a 3 Dispositivi WhatsApp
          </li>
          <li class="flex items-center gap-3 text-text-muted">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Contatti illimitati
          </li>
          <li class="flex items-center gap-3 text-text-muted">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Invii massivi (Campagne)
          </li>
          <li class="flex items-center gap-3 text-text-muted">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Assistenza Prioritaria
          </li>
        </ul>
        <a href={`${SiteConfig.dashboardUrl}/register`} class="btn-pricing-primary">
          Inizia Ora
        </a>
      </div>

      <!-- Enterprise -->
      <div class="glass-panel rounded-3xl p-8 flex flex-col border border-white/5 hover:border-white/20 transition-all">
        <h3 class="text-2xl font-bold text-white mb-2">Enterprise</h3>
        <p class="text-text-muted mb-6">Volumi altissimi e supporto dedicato.</p>
        <div class="mb-6">
          <span class="text-4xl font-bold text-white">€149</span>
          <span class="text-text-muted">/mese</span>
        </div>
        <ul class="space-y-4 mb-8 flex-1">
          <li class="flex items-center gap-3 text-text-muted">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Dispositivi WhatsApp illimitati
          </li>
          <li class="flex items-center gap-3 text-text-muted">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Contatti & Campagne illimitate
          </li>
          <li class="flex items-center gap-3 text-text-muted">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Account Manager dedicato
          </li>
          <li class="flex items-center gap-3 text-text-muted">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Integrazioni avanzate
          </li>
        </ul>
        <a href={`${SiteConfig.dashboardUrl}/register`} class="btn-pricing-secondary">
          Contattaci
        </a>
      </div>

    </div>
  </div>
</section>
