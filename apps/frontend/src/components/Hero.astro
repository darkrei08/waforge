---
// Hero.astro
const dashboardUrl = import.meta.env.PUBLIC_DASHBOARD_URL || 'http://app.localhost';
---

<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
    
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass-panel border-primary/30 text-primary text-xs font-semibold uppercase tracking-wider mb-8 animate-fade-in-up">
      <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
      Nuova Piattaforma WaForge
    </div>

    <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-8 animate-fade-in-up" style="animation-delay: 0.1s;">
      L'Automazione WhatsApp <br class="hidden md:block" />
      <span class="text-gradient-primary">definitiva per il tuo CRM</span>
    </h1>
    
    <p class="max-w-2xl mx-auto text-lg md:text-xl text-text-muted mb-10 animate-fade-in-up" style="animation-delay: 0.2s;">
      Gestisci contatti, automatizza le campagne, invia messaggi massivi e collabora in team in un'unica piattaforma progettata per scalare.
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up" style="animation-delay: 0.3s;">
      <a href={`${dashboardUrl}/register`} class="w-full sm:w-auto px-8 py-4 text-base font-semibold text-white bg-primary hover:bg-primary-dark rounded-xl transition-all shadow-[0_0_20px_rgba(37,211,102,0.4)] hover:shadow-[0_0_30px_rgba(37,211,102,0.6)] flex items-center justify-center gap-2 group">
        Registrati Gratuitamente
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
      <a href="#features" class="w-full sm:w-auto px-8 py-4 text-base font-semibold text-white glass-panel hover:bg-white/10 rounded-xl transition-all flex items-center justify-center">
        Scopri le Funzionalità
      </a>
    </div>

    <!-- Hero Mockup/Abstract Visual -->
    <div class="mt-20 relative mx-auto max-w-5xl animate-fade-in-up" style="animation-delay: 0.5s;">
      <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent z-10 h-full w-full pointer-events-none"></div>
      
      <div class="glass-panel p-2 rounded-2xl md:rounded-3xl shadow-2xl relative">
        <!-- Browser Window Mockup -->
        <div class="bg-[#1a1d24] rounded-xl md:rounded-2xl overflow-hidden border border-white/5">
          <div class="h-10 border-b border-white/5 bg-[#13151a] flex items-center px-4 gap-2">
            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
          </div>
          <div class="aspect-[16/9] bg-gradient-to-br from-[#0f1115] to-[#1a1d24] flex items-center justify-center relative overflow-hidden">
            <!-- Decorative Dashboard Abstract -->
            <div class="absolute inset-0 grid grid-cols-6 grid-rows-4 gap-4 p-8 opacity-20">
              <div class="col-span-2 row-span-4 rounded-xl bg-white/10 border border-white/5"></div>
              <div class="col-span-4 row-span-1 rounded-xl bg-primary/20 border border-primary/10"></div>
              <div class="col-span-4 row-span-3 rounded-xl bg-white/5 border border-white/5"></div>
            </div>
            
            <div class="relative z-10 flex flex-col items-center gap-4">
              <div class="w-20 h-20 bg-primary/20 rounded-2xl flex items-center justify-center border border-primary/30">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-primary animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
              </div>
              <p class="text-white/60 font-medium tracking-widest uppercase text-sm">Dashboard Preview</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    
  </div>
</section>
