---
// Hero.astro
import BentoMockup from './BentoMockup.astro';
import IconArrowRight from './icons/IconArrowRight.astro';
const dashboardUrl = import.meta.env.PUBLIC_DASHBOARD_URL || 'http://localhost:3000';
---

<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden">
  <!-- Sfondo luminoso centrale -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-[400px] bg-primary/10 rounded-full blur-[120px] pointer-events-none -z-10"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
    
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass-panel border-primary/20 text-white text-xs font-semibold tracking-wide mb-8 animate-fade-in-up">
      <span class="relative flex h-2.5 w-2.5 mr-1">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-primary"></span>
      </span>
      WaForge 2.0 è ora disponibile
    </div>

    <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 animate-fade-in-up [animation-delay:0.1s]">
      L'Automazione WhatsApp <br class="hidden md:block" />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-gray-300 to-gray-500">definitiva per il tuo</span>
      <span class="text-gradient-primary"> CRM</span>
    </h1>
    
    <p class="max-w-2xl mx-auto text-lg md:text-xl text-text-muted mb-10 animate-fade-in-up [animation-delay:0.2s]">
      Gestisci contatti, automatizza le campagne massicce senza ban, collabora con il tuo team in un'unica piattaforma premium.
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up [animation-delay:0.3s]">
      <a href={`${dashboardUrl}/register`} class="btn-primary">
        Inizia Subito
        <IconArrowRight />
      </a>
      <a href={`${dashboardUrl}/login`} class="btn-secondary">
        Accedi alla Dashboard
      </a>
    </div>

    <!-- Premium Bento Mockup Visual -->
    <BentoMockup />
    
  </div>
</section>
