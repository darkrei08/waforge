---
// BentoMockup.astro
---

<div class="mt-24 relative mx-auto max-w-5xl animate-fade-in-up" style="animation-delay: 0.5s;">
  <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent z-20 h-full w-full pointer-events-none"></div>
  
  <div class="glass-panel p-2 rounded-2xl md:rounded-3xl relative border-t border-l border-white/10 shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
    <!-- Browser Window Mockup -->
    <div class="bg-surface rounded-xl md:rounded-2xl overflow-hidden border border-white/5 relative">
      
      <div class="h-10 border-b border-white/5 bg-surface-dim flex items-center px-4 gap-2">
        <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
      </div>

      <!-- Bento Grid Inner -->
      <div class="aspect-[16/9] bg-gradient-to-br from-surface-dim to-background p-6 lg:p-8 grid grid-cols-12 grid-rows-6 gap-4 relative overflow-hidden">
        <!-- Glow effettivo sul mockup -->
        <div class="absolute -top-32 -right-32 w-64 h-64 bg-primary/20 rounded-full blur-[80px]"></div>
        
        <!-- Sidebar -->
        <div class="col-span-3 row-span-6 rounded-xl bg-white/5 border border-white/10 p-4 flex flex-col gap-3">
          <div class="h-8 w-2/3 bg-white/10 rounded-lg mb-4"></div>
          <div class="h-6 w-full bg-primary/10 border border-primary/20 rounded-md"></div>
          <div class="h-6 w-5/6 bg-white/5 rounded-md"></div>
          <div class="h-6 w-4/6 bg-white/5 rounded-md"></div>
          <div class="mt-auto h-10 w-full bg-white/5 rounded-md"></div>
        </div>

        <!-- Main KPI -->
        <div class="col-span-6 row-span-2 rounded-xl bg-gradient-to-r from-primary/20 to-primary/5 border border-primary/20 p-5 flex items-center justify-between">
           <div class="space-y-2">
             <div class="h-4 w-24 bg-white/20 rounded"></div>
             <div class="h-8 w-32 bg-white flex items-center p-1 rounded"><div class="h-4 w-1/2 bg-surface-dim rounded"></div></div>
           </div>
           <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center border border-primary/30">
             <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
           </div>
        </div>

        <!-- Secondary Card -->
        <div class="col-span-3 row-span-2 rounded-xl bg-white/5 border border-white/10 p-5">
          <div class="h-4 w-20 bg-white/20 rounded mb-4"></div>
          <div class="flex gap-2 mb-2"><div class="h-2 w-full bg-primary rounded"></div></div>
          <div class="flex gap-2 mb-2"><div class="h-2 w-3/4 bg-white/20 rounded"></div></div>
          <div class="flex gap-2"><div class="h-2 w-1/2 bg-white/20 rounded"></div></div>
        </div>

        <!-- Content Area -->
        <div class="col-span-9 row-span-4 rounded-xl bg-white/5 border border-white/10 p-5 flex flex-col gap-4">
          <div class="flex items-center justify-between border-b border-white/5 pb-4">
             <div class="h-5 w-32 bg-white/20 rounded"></div>
             <div class="h-8 w-24 bg-primary/20 border border-primary/30 rounded-lg"></div>
          </div>
          <div class="flex-1 rounded-lg bg-surface border border-white/5 p-4 space-y-3">
             <div class="flex items-center gap-3"><div class="w-8 h-8 rounded-full bg-white/10"></div><div class="flex-1 h-3 bg-white/10 rounded"></div><div class="w-16 h-3 bg-white/10 rounded"></div></div>
             <div class="flex items-center gap-3"><div class="w-8 h-8 rounded-full bg-white/10"></div><div class="flex-1 h-3 bg-white/10 rounded"></div><div class="w-16 h-3 bg-white/10 rounded"></div></div>
             <div class="flex items-center gap-3"><div class="w-8 h-8 rounded-full bg-white/10"></div><div class="flex-1 h-3 bg-white/10 rounded"></div><div class="w-16 h-3 bg-white/10 rounded"></div></div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
