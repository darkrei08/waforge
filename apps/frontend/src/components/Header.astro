---
// Header.astro
// Default URL for the Nuxt Dashboard where Auth lives. 
// In production, this can be passed via environment variables (e.g. import.meta.env.PUBLIC_DASHBOARD_URL)
import IconLogo from './icons/IconLogo.astro';
const dashboardUrl = import.meta.env.PUBLIC_DASHBOARD_URL || 'http://localhost:3000';
---

<header class="glass-nav" id="navbar">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <div class="logo-box">
        <IconLogo />
      </div>
      <span class="text-xl font-bold tracking-tight text-white">WaForge</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="#features" class="nav-link">Funzionalità</a>
      <a href="#crm" class="nav-link">CRM & Automazione</a>
      <a href="#pricing" class="nav-link">Prezzi</a>
    </nav>

    <!-- Auth Buttons (Linking to Nuxt Dashboard) -->
    <div class="flex items-center gap-4">
      <a href={`${dashboardUrl}/login`} class="text-sm font-medium text-white hover:text-primary transition-colors hidden sm:block">
        Accedi
      </a>
      <a href={`${dashboardUrl}/register`} class="btn-primary !px-5 !py-2.5 !text-sm">
        Inizia Ora
      </a>
    </div>
  </div>
</header>

<script>
  // Add background opacity on scroll
  window.addEventListener('scroll', () => {
    const navbar = document.getElementById('navbar');
    if (window.scrollY > 20) {
      navbar?.classList.add('bg-background/90', 'shadow-lg');
      navbar?.classList.remove('bg-background/70');
    } else {
      navbar?.classList.remove('bg-background/90', 'shadow-lg');
      navbar?.classList.add('bg-background/70');
    }
  });
</script>
