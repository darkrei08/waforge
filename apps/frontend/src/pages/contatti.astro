---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SiteConfig } from '../config';
---

<Layout title="Contatti - WaForge">
	<Header />
	
	<main class="pt-32 pb-20 max-w-4xl mx-auto px-6 text-white min-h-[60vh]">
		<h1 class="text-4xl font-bold mb-8 animate-fade-in-up">Contattaci</h1>
		<div class="glass-panel p-8 rounded-2xl animate-fade-in-up [animation-delay:0.1s] text-text-muted">
			<p class="text-lg mb-8 leading-relaxed">
                Hai domande o hai bisogno di supporto tecnico? Il nostro team è a tua disposizione.
            </p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="bg-surface-dim/50 p-6 rounded-xl border border-white/5">
                    <h3 class="text-xl font-bold text-white mb-2">Supporto Clienti</h3>
                    <p class="text-sm mb-4">Per assistenza sull'uso della piattaforma o segnalazione di problemi.</p>
                    <a href={`mailto:${SiteConfig.contactEmail}`} class="text-primary hover:underline">{SiteConfig.contactEmail}</a>
                </div>
                
                <div class="bg-surface-dim/50 p-6 rounded-xl border border-white/5">
                    <h3 class="text-xl font-bold text-white mb-2">Vendite & Partnership</h3>
                    <p class="text-sm mb-4">Per piani Enterprise, agenzie o proposte commerciali.</p>
                    <a href={`mailto:${SiteConfig.salesEmail}`} class="text-primary hover:underline">{SiteConfig.salesEmail}</a>
                </div>
            </div>
		</div>
	</main>

	<Footer />
</Layout>
