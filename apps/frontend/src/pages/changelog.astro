---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

let releases = [];
try {
  const response = await fetch('https://api.github.com/repos/darkrei08/waforge/releases?per_page=5', {
    headers: {
      'Accept': 'application/vnd.github.v3.html+json',
      'User-Agent': 'WaForge-Frontend'
    }
  });
  if (response.ok) {
    releases = await response.json();
  }
} catch (e) {
  console.error("Failed to fetch changelog:", e);
}
---

<Layout title="Changelog - WaForge">
	<Header />
	
	<main class="pt-32 pb-20 max-w-4xl mx-auto px-6 text-white min-h-[60vh]">
		<h1 class="text-4xl font-bold mb-8 animate-fade-in-up">Changelog</h1>
		<div class="glass-panel p-8 rounded-2xl animate-fade-in-up [animation-delay:0.1s] text-text-muted">
			<p class="text-lg mb-6">Tutte le ultime novità, aggiornamenti e bug fix della piattaforma WaForge.</p>
            
            <div class="space-y-8">
                {releases.length > 0 ? releases.map((release: any, index: number) => (
                    <div class={`border-l-2 ${index === 0 ? 'border-primary/30' : 'border-white/10'} pl-6 pb-2 relative`}>
                        <div class={`absolute w-4 h-4 rounded-full ${index === 0 ? 'bg-primary' : 'bg-white/20'} -left-[9px] top-1`}></div>
                        <h3 class="text-xl font-bold text-white">
                            Versione {release.name || release.tag_name} {index === 0 && <span class="text-sm font-normal text-primary ml-2">(Attuale)</span>}
                        </h3>
                        <p class={`text-sm ${index === 0 ? 'text-primary' : 'text-text-muted'} mb-3`}>
                            Rilasciata il {new Date(release.published_at).toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' })}
                        </p>
                        <div class="prose prose-invert prose-sm max-w-none prose-a:text-primary prose-ul:list-disc prose-ul:list-inside prose-li:mb-1 mt-4" set:html={release.body_html || release.body}></div>
                    </div>
                )) : (
                    <p class="text-white">Caricamento delle versioni in corso o non riuscito. Riprova più tardi.</p>
                )}
            </div>
		</div>
	</main>

	<Footer />
</Layout>
